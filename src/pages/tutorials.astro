---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Tutorials — DataIsland Software" description="Video tutorials and guides for FusionMD, Ordina, and CheckThis.">

  <section class="tutorials-page fade-in">
    <h1>Tutorials</h1>
    <p class="intro">Step-by-step guides for each DataIsland app. Select an app to get started.</p>

    <div class="app-grid">
      <a href="/tutorials/fusionmd" class="app-card">
        <div class="app-icon">📝</div>
        <h2>FusionMD</h2>
        <p>Document studio, Markdown editor, and professional publishing pipeline.</p>
        <span class="card-link">View tutorials →</span>
      </a>
      <a href="/tutorials/ordina" class="app-card">
        <div class="app-icon">🔍</div>
        <h2>Ordina</h2>
        <p>Multi-drive file search across local, external, cloud, and remote drives.</p>
        <span class="card-link">View tutorials →</span>
      </a>
      <a href="/tutorials/checkthis" class="app-card">
        <div class="app-icon">🛡️</div>
        <h2>CheckThis</h2>
        <p>Email phishing and fraud analysis for Apple Mail.</p>
        <span class="card-link">View tutorials →</span>
      </a>
    </div>
  </section>

</BaseLayout>

<style>
  .tutorials-page {
    max-width: 700px;
    margin: 0 auto;
    padding: 3rem 0 5rem;
    border-bottom: none;
  }

  .tutorials-page h1 {
    font-size: 2.25rem;
    margin-bottom: 1rem;
  }

  .intro {
    font-size: 1.05rem;
    color: var(--gray-dark);
    margin-bottom: 3rem;
  }

  .app-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1.5rem;
  }

  .app-card {
    display: block;
    background: var(--gray-light);
    border-radius: var(--radius);
    padding: 2rem 1.5rem;
    text-decoration: none;
    color: inherit;
    transition: var(--transition);
  }

  .app-card:hover {
    background: var(--blue-light);
    opacity: 1;
  }

  .app-icon { font-size: 2rem; margin-bottom: 0.75rem; }

  .app-card h2 { font-size: 1.2rem; margin-bottom: 0.5rem; }

  .app-card p {
    font-size: 0.92rem;
    color: var(--gray);
    line-height: 1.5;
    margin-bottom: 1rem;
  }

  .card-link {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--blue);
  }
</style>
