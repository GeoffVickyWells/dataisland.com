---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Tutorials — DataIsland Software" description="Video tutorials and guides for FusionMD, Ordina, and CheckThis.">

  <section class="tutorials-page fade-in">
    <h1>Tutorials</h1>
    <p class="intro">
      Step-by-step guides for FusionMD, Ordina, and CheckThis.
      Video tutorials are coming — check back after launch.
    </p>

    <div class="coming-soon-block">
      <div class="icon">🎬</div>
      <h2>Coming Soon</h2>
      <p>
        We're recording tutorial videos for each app. In the meantime, each product
        page covers the key features in detail.
      </p>
      <div class="product-links">
        <a href="/products/fusionmd">FusionMD →</a>
        <a href="/products/ordina">Ordina →</a>
        <a href="/products/checkthis">CheckThis →</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .tutorials-page {
    max-width: 700px;
    margin: 0 auto;
    padding: 3rem 0 5rem;
    border-bottom: none;
  }

  .tutorials-page h1 {
    font-size: 2.25rem;
    margin-bottom: 1rem;
  }

  .intro {
    font-size: 1.05rem;
    color: var(--gray-dark);
    margin-bottom: 3rem;
  }

  .coming-soon-block {
    text-align: center;
    background: var(--gray-light);
    border-radius: var(--radius);
    padding: 3rem 2rem;
  }

  .icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .coming-soon-block h2 {
    font-size: 1.4rem;
    margin-bottom: 0.75rem;
  }

  .coming-soon-block p {
    font-size: 1rem;
    color: var(--gray-dark);
    max-width: 450px;
    margin: 0 auto 1.5rem;
    line-height: 1.6;
  }

  .product-links {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
  }

  .product-links a {
    font-weight: 600;
    font-size: 0.95rem;
  }
</style>
