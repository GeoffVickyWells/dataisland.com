---
import ProductLayout from "../../layouts/ProductLayout.astro";

const title = "CheckThis";
const icon = "/images/products/checkthis/icon.png";
const tagline = "A privacy‑first email trust analyzer for macOS and iOS.";
---

<ProductLayout {title} {icon} {tagline}>
  <h2>Overview</h2>
  <p>
    CheckThis helps you understand whether an email is legitimate — without
    sending anything to the cloud. Everything runs locally, giving you clarity
    and confidence without compromising privacy.
  </p>

  <h2>Key Features</h2>
  <ul>
    <li>Local analysis — nothing leaves your device</li>
    <li>Clear explanations of risks and signals</li>
    <li>Simple, friendly interface</li>
    <li>Works with macOS and iOS Mail</li>
  </ul>

  <h2>Why You'll Love It</h2>
  <p>
    CheckThis gives you peace of mind in a world where phishing and spoofing are
    increasingly sophisticated.
  </p>

  <a href="#" class="cta">Download</a>
</ProductLayout>
