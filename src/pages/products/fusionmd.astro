---
import ProductLayout from "../../layouts/ProductLayout.astro";

const title = "FusionMD";
const icon = "/images/products/fusionmd/icon.png";
const tagline = "Semantic writing for professionals and creators.";
---

<ProductLayout {title} {icon} {tagline}>
  <h2>Overview</h2>
  <p>
    FusionMD bridges the gap between AI‑generated content and professional
    publishing. It gives you semantic structure, clean exports, and a workflow
    that scales from simple documents to complex, multi‑section projects.
  </p>

  <h2>Key Features</h2>
  <ul>
    <li>Semantic Markdown with structure you control</li>
    <li>Professional exports to DOCX, PDF, HTML, and more</li>
    <li>AI‑assisted drafting and refinement</li>
    <li>Perfect for reports, guides, and long‑form writing</li>
  </ul>

  <h2>Why You'll Love It</h2>
  <p>
    FusionMD gives you the power of a full publishing pipeline without the
    complexity of traditional layout tools.
  </p>

  <a href="#" class="cta">Learn More</a>
</ProductLayout>
