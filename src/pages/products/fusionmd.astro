---
import BaseLayout from "../../layouts/BaseLayout.astro";
import EmailCapture from "../../components/EmailCapture.astro";
import AppFAQ from "../../components/AppFAQ.astro";
import AppStoreCTA from "../../components/AppStoreCTA.astro";

const icon = "/images/products/fusionmd/icon.png";
---

<BaseLayout
  title="FusionMD — From First Word to Final Layout"
  description="FusionMD is a native Mac document studio combining a Markdown editor, AI writing assistant, template engine, and professional IDML publishing pipeline."
>

  <!-- Hero -->
  <section class="product-hero fade-in">
    <img src={icon} alt="FusionMD" class="product-icon" />
    <h1>FusionMD</h1>
    <p class="tagline">From first word to final layout.</p>
    <p class="hero-sub">
      A native Mac document studio that combines a beautiful Markdown editor, an AI writing
      assistant, a template engine, and a professional publishing pipeline — all in one app.
      The only Markdown editor that exports directly to Affinity and InDesign.
    </p>
    <div class="hero-meta">macOS 14 Sonoma or later &nbsp;·&nbsp; 30-day free trial &nbsp;·&nbsp; One-time purchase</div>
    <AppStoreCTA />
  </section>

  <!-- Three-level callouts -->
  <section class="three-levels fade-in">
    <div class="level">
      <div class="level-num">01</div>
      <h3>Write</h3>
      <p>A beautiful Markdown editor with live preview, focus mode, and AI assistance. Every document is plain Markdown — readable by any tool, exportable anywhere.</p>
    </div>
    <div class="level">
      <div class="level-num">02</div>
      <h3>Create</h3>
      <p>A template engine with <code>{"{{variable}}"}</code> placeholders, typed fields, and conditional sections. Fill a proposal, contract, or report in under a minute.</p>
    </div>
    <div class="level">
      <div class="level-num">03</div>
      <h3>Publish</h3>
      <p>Export to IDML — the format Affinity and InDesign speak natively. Tag content with style names and hand a perfectly structured file to your layout tool.</p>
    </div>
  </section>

  <!-- Feature 1: IDML Export (lead differentiator) -->
  <section class="feature-section fade-in">
    <div class="feature-icon">📐</div>
    <div class="feature-body">
      <h2>The only Markdown editor that exports to IDML.</h2>
      <p>
        IDML is the professional layout format — the file format that Affinity
        and Adobe InDesign open. No other Markdown editor on the market can produce it.
      </p>
      <p>
        FusionMD takes an AI-generated or hand-written document with named paragraph styles
        and exports a properly structured IDML file. Your layout tool opens it with heading
        styles, body text, captions, and pull quotes already tagged — ready to design, not
        ready to re-type.
      </p>
      <div class="callout">
        Works with <strong>Affinity</strong> and <strong>Adobe InDesign</strong>.
        The IDML spec is open and widely supported.
      </div>
    </div>
  </section>

  <!-- Feature 2: The Editor -->
  <section class="feature-section fade-in alt">
    <div class="feature-icon">✍️</div>
    <div class="feature-body">
      <h2>A writing environment that stays out of your way.</h2>
      <p>
        Full CommonMark and GitHub Flavored Markdown with live syntax highlighting.
        Bold is bold while you type. Headings are large. Code is monospaced.
        A floating format bar keeps every Markdown element one tap away.
      </p>
      <div class="mini-feature-grid">
        <div class="mini-feature">
          <h3>Focus Mode</h3>
          <p>Dims every line but the one you're writing. The rest of the document fades to the background.</p>
        </div>
        <div class="mini-feature">
          <h3>Typewriter Mode</h3>
          <p>Holds your cursor in the center of the screen as you type — no more eyes chasing the bottom.</p>
        </div>
        <div class="mini-feature">
          <h3>Live Preview</h3>
          <p>Split view updates as you type. Drag the divider between full editor, full preview, or anywhere between.</p>
        </div>
        <div class="mini-feature">
          <h3>19 App Themes</h3>
          <p>Light, dark, and everything between — named color palettes that change the whole writing environment, not just a mode toggle.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature 3: App Themes -->
  <section class="feature-section fade-in alt">
    <div class="feature-icon">🎨</div>
    <div class="feature-body">
      <h2>Your writing environment, your color.</h2>
      <p>
        Most writing apps give you a light/dark toggle — if you're lucky. FusionMD ships
        with 19 named color themes covering the full spectrum from crisp white to deep espresso,
        with a dozen variations in between. Pick the environment you want to write in, not
        the one the developer decided on.
      </p>
      <p>
        Each theme sets the editor background, sidebar, toolbar, and accent color as a
        coordinated palette — not just a tint applied over a fixed grey UI. Switch to
        Hot Coffee and everything goes dark brown with latte cream accents. Switch to
        Sandstone and the whole app becomes warm editorial cream. The writing surface
        you stare at for hours deserves to look the way you want it to.
      </p>

      <div class="app-theme-columns">
        <div class="app-theme-group">
          <div class="app-theme-group-label">Light</div>
          <div class="app-theme-chips">
            <span>System</span>
            <span>Sandstone</span>
            <span>Minimalist</span>
            <span>Crystal Ice</span>
            <span>Golden Hour</span>
            <span>Health</span>
            <span>Pina Colada</span>
            <span>Tuscan Honey</span>
          </div>
        </div>
        <div class="app-theme-group">
          <div class="app-theme-group-label">Dark</div>
          <div class="app-theme-chips">
            <span>Slate</span>
            <span>Forest</span>
            <span>Graphite</span>
            <span>Rosewood</span>
            <span>Indigo</span>
            <span>Flamingo</span>
            <span>Evergreen</span>
            <span>Hot Coffee</span>
            <span>Pumpkin</span>
            <span>Spiced Honey</span>
            <span>Winter Storm</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature 4: AI -->
  <section class="feature-section fade-in">
    <div class="feature-icon">🧠</div>
    <div class="feature-body">
      <h2>AI that understands your document — not just your text.</h2>
      <p>
        The AI in FusionMD is not a chatbot tacked on. It knows whether you are drafting
        a blog post, filling a contract template, laying out a report, or scripting a
        screenplay — and it adapts its behavior accordingly.
      </p>
      <ul class="feature-list">
        <li>
          <strong>Apple Intelligence</strong> — on-device, completely private.
          Requires Apple Silicon + macOS 26 + Apple Intelligence enabled.
          No API key. No data leaves your Mac.
        </li>
        <li>
          <strong>OpenRouter</strong> — cloud-based, user-supplied API key.
          Choose from Claude, GPT-4o, Gemini, and more.
          Email content sent to OpenRouter under their privacy policy.
        </li>
        <li>
          <strong>Neither</strong> — FusionMD is fully functional without AI.
          Write and export without any AI configuration.
        </li>
      </ul>
    </div>
  </section>

  <!-- Feature 4: Templates -->
  <section class="feature-section fade-in alt">
    <div class="feature-icon">📋</div>
    <div class="feature-body">
      <h2>Templates with real power.</h2>
      <p>
        Build a document template with <code>{"{{variable}}"}</code> placeholders — typed fields,
        required-field enforcement, and boolean conditions that show or hide entire sections
        based on what you fill in.
      </p>
      <p>
        Create the template once. Fill it in seconds. Save any document as a reusable template.
        Share templates as <code>.fusiontemplate</code> files.
      </p>
      <div class="callout">
        Useful for: proposals, contracts, reports, interview write-ups, brief templates,
        recurring newsletters, and any document type you produce more than once.
      </div>
    </div>
  </section>

  <!-- Feature 5: Fountain / Screenplay -->
  <section class="feature-section fade-in">
    <div class="feature-icon">🎬</div>
    <div class="feature-body">
      <h2>A dedicated Fountain screenplay mode.</h2>
      <p>
        FusionMD is the only Markdown editor with a proper Fountain screenplay mode: Courier 12pt
        rendering, scene navigator, two-row format bar with Action / Character / Dialogue / Transition
        shortcuts, and industry-standard PDF export.
      </p>
      <p>
        Screenwriters get a professional tool. Power users get one less app.
      </p>
    </div>
  </section>

  <!-- Feature 6: Writing Coach -->
  <section class="feature-section fade-in alt">
    <div class="feature-icon">🖊️</div>
    <div class="feature-body">
      <h2>A complete Writing Coach, built into the right panel.</h2>
      <p>
        No extra apps, no subscriptions. Every writing analysis tool lives in one tab and
        updates as you work. Select a word — the thesaurus and dictionary fill instantly.
        Switch tools with a single icon tap.
      </p>
      <div class="coach-grid">
        <div class="coach-card">
          <h3>Spell Check</h3>
          <p>Scans the full document and lists every misspelled word. Click any suggestion chip to apply the correction instantly — the list updates as you fix.</p>
        </div>
        <div class="coach-card">
          <h3>Grammar</h3>
          <p>Goes beyond red underlines. Surfaces macOS's plain-English descriptions of each grammar issue — what's wrong and why — with one-click correction buttons where available.</p>
        </div>
        <div class="coach-card">
          <h3>Thesaurus</h3>
          <p>Select any word to see synonyms, antonyms, and related terms from the Datamuse API. Click a synonym to replace the word in your document in one step.</p>
        </div>
        <div class="coach-card">
          <h3>Dictionary</h3>
          <p>Full definitions, phonetic pronunciation, part of speech, and example sentences — right in the panel. Language-aware. Powered by the Free Dictionary API. No browser required.</p>
        </div>
        <div class="coach-card">
          <h3>Overused Words</h3>
          <p>On-device lemma analysis scans the full document and flags content words you have used too frequently. Spot repetition before your readers do.</p>
        </div>
        <div class="coach-card">
          <h3>Proofreader</h3>
          <p>Catches unfilled placeholders, repeated phrases, unmatched punctuation, long sentences, capitalisation errors, and word-usage mistakes. Click any issue to jump to it.</p>
        </div>
        <div class="coach-card">
          <h3>Style &amp; Clarity</h3>
          <p>Highlights adjectives, adverbs, passive voice, and filler words throughout the document. Live Flesch-Kincaid readability score updates as you edit.</p>
        </div>
        <div class="coach-card">
          <h3>Parts of Speech</h3>
          <p>Colour-codes every word by grammatical category — nouns, verbs, adjectives, adverbs, and four more. Works across 10+ languages, entirely on-device.</p>
        </div>
      </div>
      <p class="coach-note">
        All analysis runs locally or via free, key-free public APIs —
        nothing sensitive leaves your machine.
      </p>
      <div class="coach-polish">
        <h3>AI Polish — rewrite any selection, four ways</h3>
        <p>
          Select a passage, open the Cleanup tab, and choose your mode:
          <strong>Polish</strong> (full professional edit),
          <strong>Fix Errors</strong> (proofreading only),
          <strong>Shorten</strong> (half the length, all the meaning), or
          <strong>Simplify</strong> (plain language). The rewritten version
          appears in the panel for review — apply it or discard it, nothing
          changes until you decide. Requires Apple Intelligence or an
          OpenRouter API key.
        </p>
      </div>
    </div>
  </section>

  <!-- Feature 7: Languages & Translation -->
  <section class="feature-section fade-in">
    <div class="feature-icon">🌍</div>
    <div class="feature-body">
      <h2>21 languages. Set once, everything adapts.</h2>
      <p>
        Setting the document language is a single action that changes five things at once:
        spell checking, smart quotes, typographic spacing, AI context, and dialogue correction
        all switch automatically. You don't configure each feature separately.
      </p>

      <div class="lang-grid">
        <div class="lang-card">
          <h3>Smart Quotes</h3>
          <p>The correct quotation style for the document's language, applied automatically as you type.</p>
          <table class="quote-table">
            <tr><td>English</td><td class="mono">"Hello"</td></tr>
            <tr><td>French / Spanish</td><td class="mono">«Bonjour»</td></tr>
            <tr><td>German</td><td class="mono">„Hallo"</td></tr>
            <tr><td>Chinese (Traditional)</td><td class="mono">「你好」</td></tr>
          </table>
        </div>
        <div class="lang-card">
          <h3>French Typographic Spacing</h3>
          <p>When the document language is French (Canada or France), a French Spacing button inserts the correct narrow no-break space before <span class="mono">! ? ; :</span> — the convention used in professional French publishing.</p>
        </div>
        <div class="lang-card">
          <h3>English Variant Scanning</h3>
          <p>For US, UK, and Australian English: detects out-of-convention spellings and vocabulary (38 spelling pairs, 23 vocabulary pairs) and offers to convert in either direction.</p>
          <p class="lang-note">Disabled for English (Canada) — both US and UK spellings are correct in Canadian English and Fusion won't flag them.</p>
        </div>
        <div class="lang-card">
          <h3>AI Writes in Your Language</h3>
          <p>The document language is passed to the AI on every generation request. Ask for a paragraph and it writes in the document's language — using correct vocabulary, spelling conventions, and punctuation style — without you having to say "write in French" each time.</p>
        </div>
      </div>

      <div class="canada-callout">
        <strong>Built for Canada's two official languages.</strong>
        <p>
          <strong>English (Canada)</strong> accepts both US and UK spellings — because both are correct.
          Fusion won't flag "colour" or tell you "centre" is misspelled in a Canadian document.
        </p>
        <p>
          <strong>Français (Canada)</strong> is a fully implemented locale: fr-CA dictionary,
          guillemets (« »), correct French typographic spacing, and AI that writes in Quebec French.
        </p>
        <p class="lang-note">
          Fusion is the only Mac document editor that treats English Canada and French Canada
          as the first-class, distinct writing environments they are.
        </p>
      </div>

      <h3>On-Device Translation <span class="badge">macOS 15+</span></h3>
      <p>
        On macOS 15 Sequoia or later, translate an entire document into another language — or just
        a selected passage — entirely on your Mac. Paragraph structure is preserved. No API key,
        no cloud service, no data sent anywhere. Powered by Apple's Translation framework.
      </p>
      <p>
        Two modes: <strong>Full document → new window</strong> (original untouched) or
        <strong>Selection → in-place replacement</strong> (translate one paragraph while
        leaving the rest unchanged). Language packs are downloaded once by macOS and then
        run offline.
      </p>

      <div class="lang-chips">
        <span>English (US)</span><span>English (Canada)</span><span>English (UK)</span>
        <span>English (Australia)</span><span>Français (Canada)</span><span>Français (France)</span>
        <span>Español</span><span>Italiano</span><span>Deutsch</span><span>Svenska</span>
        <span>Русский</span><span>Português (BR)</span><span>Português (PT)</span>
        <span>中文 (简体)</span><span>中文 (繁體)</span><span>日本語</span><span>한국어</span>
        <span>हिन्दी</span><span>Welsh</span><span>Irish</span><span>Scottish Gaelic</span>
      </div>
    </div>
  </section>

  <!-- Feature 8: Text Themes -->
  <section class="feature-section fade-in">
    <div class="feature-icon">🎨</div>
    <div class="feature-body">
      <h2>Typography that matches the document — not just the font.</h2>
      <p>
        Word and Pages give you a font picker. FusionMD gives you document conventions.
      </p>
      <p>
        A Text Theme is a complete typography system: font family, body size, line height,
        paragraph spacing, first-line indent, heading hierarchy, table style, and page margins
        — tuned together for a specific kind of writing. Switch from Novel to Contract and
        every typographic decision updates: not just the typeface, but the conventions
        that make that document look correct.
      </p>
      <p>
        Word's style sets change the font. They don't know that a legal contract double-spaces
        at 12pt with stepped-indent headings, that an academic paper follows APA 7th edition
        heading rules, or that literary fiction uses first-line indents with no inter-paragraph
        gap. FusionMD builds those conventions in — one click, everything right.
      </p>

      <div class="theme-grid">
        <div class="theme-card">
          <h3>To Do List</h3>
          <p>System font with indented heading levels that double as section categories — a visual outline without a sidebar.</p>
        </div>
        <div class="theme-card">
          <h3>Minimal</h3>
          <p>Clean monospaced font, block paragraphs, narrow margins. Plain writing without distraction.</p>
        </div>
        <div class="theme-card">
          <h3>Typewriter</h3>
          <p>Courier New with first-line indents and uppercase chapter headings — the classic draft manuscript look.</p>
        </div>
        <div class="theme-card">
          <h3>Novel</h3>
          <p>Palatino serif, generous 1.85× leading, first-line indents, no inter-paragraph gap — longform narrative and fiction.</p>
        </div>
        <div class="theme-card">
          <h3>Contract</h3>
          <p>Times New Roman, double-spaced, stepped heading indentation following legal document conventions.</p>
        </div>
        <div class="theme-card">
          <h3>Academic</h3>
          <p>Georgia serif, double-spaced, APA 7th edition heading hierarchy — university papers and research.</p>
        </div>
        <div class="theme-card">
          <h3>Technical</h3>
          <p>System font, bold heading scale, monospaced code and blockquotes — developer docs and READMEs.</p>
        </div>
        <div class="theme-card">
          <h3>Report</h3>
          <p>Compact system font with progressive heading indents for business reports, proposals, and executive summaries.</p>
        </div>
        <div class="theme-card">
          <h3>Newsletter</h3>
          <p>Georgia serif with editorial proportions — newsletters, blog posts, and magazine-style writing.</p>
        </div>
      </div>

      <div class="callout">
        Every theme is fully customisable. Save your own typography system as a custom theme and it becomes available across all your documents.
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="pricing-section fade-in">
    <h2>Simple, honest pricing.</h2>
    <div class="pricing-cards">
      <div class="pricing-card">
        <h3>Free Trial</h3>
        <div class="price">30 days</div>
        <div class="price-detail">no credit card required</div>
        <ul>
          <li>Full editor — no feature limits</li>
          <li>Templates and variables</li>
          <li>IDML export</li>
          <li>AI assistant (Apple Intelligence or OpenRouter)</li>
          <li>Fountain screenplay mode</li>
          <li>Full Writing Coach — spell check, grammar, thesaurus, dictionary &amp; more</li>
        </ul>
      </div>
      <div class="pricing-card featured">
        <h3>FusionMD</h3>
        <div class="price">$49.99</div>
        <div class="price-detail">one-time purchase · no subscription</div>
        <ul>
          <li>Everything in the trial</li>
          <li>Unlimited documents</li>
          <li>Templates and <code style="background:rgba(255,255,255,0.15); padding: 0.1em 0.3em; border-radius:4px">{"{{variables}}"}</code></li>
          <li>IDML export to Affinity &amp; InDesign</li>
          <li>Fountain mode</li>
          <li>Buy once · yours forever</li>
        </ul>
      </div>
    </div>
    <p class="pricing-compare">
      Comparable to iA Writer ($49.99) — with templates, IDML export, and Fountain mode that iA Writer doesn't have.
    </p>
  </section>

  <!-- FAQ -->
  <AppFAQ items={[
    {
      question: "What does FusionMD use AI for?",
      answer: "FusionMD uses AI for four things: generating or expanding content (draft a paragraph, write a section, continue where you left off); rewriting and polishing (adjust tone, improve clarity, make it shorter); explaining grammar — the Parts of Speech panel can ask AI to explain why a word functions as a particular part of speech in that specific sentence; and context-aware assistance — the AI knows whether you are writing Markdown, filling a template, or building a screenplay, and adapts its suggestions accordingly. AI is optional: every feature except AI generation works without any AI configuration."
    },
    {
      question: "Can the AI write in languages other than English?",
      answer: "Yes. When you set the document language — say, French (Canada) or German — that language is passed to the AI on every generation request. Ask for a paragraph and the AI writes in the document's language with correct spelling conventions, vocabulary, and punctuation style. You never need to say \"write in French\" each time. This works with both Apple Intelligence and OpenRouter-connected models."
    },
    {
      question: "What are Boilerplates and how do I use them?",
      answer: "A Boilerplate is a reusable chunk of content — a paragraph, a section, a disclaimer, a signature block — that you have written once and want to insert repeatedly. Unlike a Template (which is a whole-document starting point), a Boilerplate is a piece you drop into any document mid-writing. Store your standard contract clause, your author bio, your product description — then insert it in one click from the Boilerplate panel. Boilerplates are stored on your Mac and work offline."
    },
    {
      question: "How do I use AI to build content for Affinity or InDesign?",
      answer: "Use AI to generate multiple distinct content blocks — a headline, a product description, a pull quote, a caption — each as its own document or section with the appropriate paragraph style applied (Heading 1, Body, Pull Quote). When you export to IDML, FusionMD maps those style names into the IDML file. Open the IDML in Affinity or InDesign and the content arrives pre-tagged and ready to flow into your layout. You can generate, review, and refine the text entirely in FusionMD before the layout app ever opens."
    },
    {
      question: "Can I use FusionMD without AI?",
      answer: "Completely. The editor, templates, boilerplates, IDML export, Fountain screenplay mode, the full Writing Coach (spell check, grammar, thesaurus, dictionary, proofreader, style analysis, and more), and the full language system all work without any AI. You don't need an Apple Intelligence device, and you don't need an OpenRouter API key. AI is an optional layer on top of a fully functional writing and publishing tool."
    },
    {
      question: "What is the difference between a Template and a Boilerplate?",
      answer: "A Template is a whole-document starting point — a blank form with {{variable}} placeholders, required fields, and conditional sections that you fill in to produce a complete document. A Boilerplate is a reusable passage you insert mid-document at any point. Think of Templates as forms and Boilerplates as a clipboard of pre-written content. You can use both in the same document: start from a template, then insert boilerplates to fill the variable sections."
    },
    {
      question: "What file format does FusionMD use?",
      answer: "FusionMD saves documents as .fusiondoc files. A .fusiondoc is a plain Markdown file with a small metadata header that stores the document title, language setting, and variable values if the document was created from a template. You can open any .fusiondoc in a plain text editor and read the Markdown. FusionMD also opens plain .md files directly. Templates are saved as .fusiontemplate files and work the same way."
    },
    {
      question: "Do I need Affinity or InDesign to use FusionMD?",
      answer: "No. FusionMD is a complete writing tool without either. IDML export is the publishing bridge for users who do page layout, but it is one feature of many. If you write blog posts, reports, screenplays, or template-driven documents and never open a layout tool, FusionMD is still the right tool."
    },
    {
      question: "How is FusionMD different from iA Writer or Ulysses?",
      answer: "iA Writer and Ulysses are excellent focused Markdown editors. FusionMD goes further in three ways. First, templates: {{variable}} placeholders, typed fields, required-field enforcement, and conditional sections — neither iA Writer nor Ulysses has anything close. Second, boilerplates: a managed library of reusable content blocks. Third, IDML export: the ability to hand a properly tagged document to Affinity or InDesign. FusionMD is priced identically to iA Writer and adds capabilities neither competitor ships."
    }
  ]} />

  <!-- Waitlist -->
  <section class="waitlist-section fade-in">
    <EmailCapture app="FusionMD" />
    <p class="privacy-note">
      By joining you agree to our <a href="/terms">Terms of Use</a>.
      Read the <a href="/privacy/fusionmd">FusionMD Privacy Policy</a>.
    </p>
  </section>

</BaseLayout>

<style>
  .product-hero {
    text-align: center;
    padding: 4rem 0 3rem;
    max-width: 700px;
    margin: 0 auto;
  }

  .product-icon {
    width: 96px;
    height: 96px;
    border-radius: 22px;
    margin-bottom: 1.5rem;
  }

  .product-hero h1 {
    font-size: 2.75rem;
    margin-bottom: 0.5rem;
  }

  .tagline {
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--blue);
    margin-bottom: 1rem;
  }

  .hero-sub {
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--gray-dark);
    margin-bottom: 1.5rem;
  }

  .hero-meta {
    font-size: 0.9rem;
    color: var(--gray);
  }

  /* Three-level callouts */
  .three-levels {
    display: flex;
    gap: 1.5rem;
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem 0 3rem;
    border-bottom: 1px solid var(--gray-light);
  }

  .level {
    flex: 1;
    background: var(--gray-light);
    border-radius: var(--radius);
    padding: 1.5rem;
  }

  .level-num {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--blue);
    margin-bottom: 0.5rem;
