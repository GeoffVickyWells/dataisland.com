---
import BaseLayout from "../../layouts/BaseLayout.astro";
import EmailCapture from "../../components/EmailCapture.astro";
import AppScreenshots from "../../components/AppScreenshots.astro";
import AppFAQ from "../../components/AppFAQ.astro";
import AppStoreCTA from "../../components/AppStoreCTA.astro";

const icon = "/images/products/ordina/icon.png";
---

<BaseLayout
  title="Ordina — Find Any File on Any Drive"
  description="Ordina indexes every file on every drive — internal, external, network, cloud, and remote — and makes them all searchable in under a second."
>

  <!-- Hero -->
  <section class="product-hero fade-in">
    <img src={icon} alt="Ordina" class="product-icon" />
    <h1>Ordina</h1>
    <p class="tagline">Every drive. One search.</p>
    <p class="hero-sub">
      Your files are on six drives. You know a file exists. You spend five minutes finding it.
      Ordina builds a local index of every drive you connect and searches them all
      simultaneously — in under a second.
    </p>
    <div class="hero-meta">macOS 12 Monterey or later &nbsp;·&nbsp; Free for one drive &nbsp;·&nbsp; Pro unlocks everything</div>
    <AppStoreCTA />
  </section>

  <!-- Feature 1: The problem -->
  <section class="feature-section fade-in">
    <div class="feature-icon">🗂️</div>
    <div class="feature-body">
      <h2>Spotlight stops at your front door.</h2>
      <p>
        macOS Spotlight doesn't index external drives, network shares, or cloud storage.
        Finder search is slow and incomplete. If a file isn't on your internal drive,
        finding it means opening each drive, one at a time, and hoping.
      </p>
      <p>
        Ordina indexes every drive you add and returns results across all of them from
        a single search box. Sub-second search, sorted by relevance, name, size, date,
        or source drive.
      </p>
    </div>
  </section>

  <!-- Feature 2: Drive types (Free vs Pro) -->
  <section class="feature-section fade-in alt">
    <div class="feature-icon">💾</div>
    <div class="feature-body">
      <h2>Add any drive. Search all of them.</h2>
      <p>Ordina is free for one local drive. Pro unlocks every other drive type.</p>
      <table class="drive-table">
        <thead>
          <tr>
            <th>Drive type</th>
            <th>Examples</th>
            <th>Free</th>
            <th>Pro</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Internal</td>
            <td>Your Mac's built-in SSD</td>
            <td class="check">✓</td>
            <td class="check">✓</td>
          </tr>
          <tr>
            <td>External</td>
            <td>USB drives, Thunderbolt SSDs, SD cards</td>
            <td class="dash">—</td>
            <td class="check">✓</td>
          </tr>
          <tr>
            <td>Network</td>
            <td>SMB shares, NAS devices, AFP servers</td>
            <td class="dash">—</td>
            <td class="check">✓</td>
          </tr>
          <tr>
            <td>Cloud</td>
            <td>Google Drive, OneDrive, Dropbox, iCloud Drive</td>
            <td class="dash">—</td>
            <td class="check">✓</td>
          </tr>
          <tr>
            <td>Remote via Agent</td>
            <td>Any Mac or NAS on your local network</td>
            <td class="dash">—</td>
            <td class="check">✓</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- Feature 3: Ordina Agent -->
  <section class="feature-section fade-in">
    <div class="feature-icon">🌐</div>
    <div class="feature-body">
      <h2>Index a NAS or another Mac — no cable required.</h2>
      <p>
        For drives that can't be physically connected, the Ordina Agent is a lightweight
        command-line tool that runs on the remote machine. It scans the drive, builds an
        index, and announces itself on your local network. Ordina on your Mac discovers it
        automatically.
      </p>
      <p>
        Works with any Mac, including headless servers and NAS devices. No cloud. No VPN.
        Just your local network.
      </p>
      <div class="code-block">
        <code># Run on the remote machine:<br />ordina-agent /Volumes/MyNAS</code>
      </div>
    </div>
  </section>

  <!-- Feature 4: Search + Filters -->
  <section class="feature-section fade-in alt">
    <div class="feature-icon">🔎</div>
    <div class="feature-body">
      <h2>Search any way you think.</h2>
      <div class="mini-feature-grid">
        <div class="mini-feature">
          <h3>Natural language</h3>
          <p>Type "large video files from last month" — Ordina converts it to a structured filter automatically. On-device, no cloud.</p>
        </div>
        <div class="mini-feature">
          <h3>Saved filters</h3>
          <p>Build a filter from file type, size, date, and tags. Name it, give it an icon. One click from the sidebar runs it across every drive.</p>
        </div>
        <div class="mini-feature">
          <h3>Tags and notes</h3>
          <p>Apply your own labels to any file or folder. Add free-text notes. Filter results by one or more tags. Your files aren't modified.</p>
        </div>
        <div class="mini-feature">
          <h3>Duplicate finder</h3>
          <p>Find exact duplicate files across every indexed drive using SHA-256 content hashing. Open in Finder, delete what you don't need.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature 5: Storage Analysis -->
  <section class="feature-section fade-in">
    <div class="feature-icon">📊</div>
    <div class="feature-body">
      <h2>See exactly what's using space.</h2>
      <p>
        The Storage Analysis view shows the largest files and folders on any drive.
        Toggle hidden files to surface what macOS keeps out of sight. Click any item
        to open in Finder and decide what to do with it.
      </p>
      <p>
        Ordina never deletes anything automatically. You see, you decide, you act.
      </p>
    </div>
  </section>

  <!-- Screenshots -->
  <AppScreenshots
    heading="See it in action"
    screenshots={[
      { src: "/images/products/ordina/screenshots/1.png", alt: "Ordina search results across multiple drives", caption: "Search every connected drive in under a second — sorted by relevance, name, size, or date." },
      { src: "/images/products/ordina/screenshots/2.png", alt: "Ordina duplicate file detection", caption: "Find duplicates scattered across cloud services and local drives — with one-click resolution." },
      { src: "/images/products/ordina/screenshots/3.png", alt: "Ordina storage analysis view", caption: "Storage Analysis — see exactly what's eating your space, including hidden files macOS keeps out of sight." },
      { src: "/images/products/ordina/screenshots/4.png", alt: "Ordina filtered search by file type", caption: "Filter by file type, size, date, or tags — then save any combination as a one-click sidebar filter." },
      { src: "/images/products/ordina/screenshots/5.png", alt: "Ordina font browsing with preview", caption: "Browse every font across all your drives with a live preview panel — no app switching required." },
      { src: "/images/products/ordina/screenshots/6.png", alt: "Ordina picture folder browsing", caption: "Picture folders with instant preview — across every connected drive, not just the internal one." },
      { src: "/images/products/ordina/screenshots/7.png", alt: "Ordina music and media files", caption: "Music and media files — sorted, searchable, and always findable no matter which drive they live on." },
    ]}
  />

  <!-- Privacy -->
  <section class="feature-section fade-in alt">
    <div class="feature-icon">🔒</div>
    <div class="feature-body">
      <h2>Your files stay on your Mac.</h2>
      <p>
        Ordina stores all index data locally in Application Support. There is no Ordina server.
        There is no account. Cloud drive credentials are stored only in your macOS Keychain.
        The natural language filter runs on-device.
      </p>
      <p>
        The only outbound network activity: OAuth flows for cloud providers (in-app, credentials
        stored in Keychain) and Bonjour for Agent discovery (LAN only, no internet).
      </p>
    </div>
  </section>

  <!-- Pricing -->
  <section class="pricing-section fade-in">
    <h2>Simple, honest pricing.</h2>
    <div class="pricing-cards">
      <div class="pricing-card">
        <h3>Free</h3>
        <div class="price">$0</div>
        <div class="price-detail">forever · no time limit</div>
        <ul>
          <li>Index and search your internal drive</li>
          <li>Full search: sort, filter, file types</li>
          <li>Tags and file notes</li>
          <li>Saved custom filters</li>
          <li>Natural language filter assistant</li>
          <li>Duplicate detection</li>
          <li>Storage analysis</li>
        </ul>
      </div>
      <div class="pricing-card featured">
        <h3>Ordina Pro</h3>
        <div class="price">$79.99</div>
        <div class="price-detail">one-time purchase · no subscription</div>
        <ul>
          <li>External drives (USB, Thunderbolt)</li>
          <li>Network drives (SMB, AFP, NFS)</li>
          <li>Cloud drives (Google Drive, OneDrive, Dropbox, iCloud)</li>
          <li>Ordina Agent for remote drives</li>
          <li>Unlimited drives</li>
          <li>Buy once · yours forever</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <AppFAQ items={[
    {
      question: "How is Ordina different from Spotlight?",
      answer: "Spotlight only indexes your internal drive. Ordina indexes every drive you add — external drives, network shares, cloud storage, and remote machines via the Ordina Agent — and searches them all simultaneously from a single interface. It also goes further with duplicate detection, storage analysis, saved filters, and file tagging."
    },
    {
      question: "Does Ordina need to be running to search?",
      answer: "Yes — Ordina maintains a local index built when you add a drive. Search is instant because you're querying that index rather than scanning the drive in real time. The index does not track changes automatically; simply hit Reindex any time you want to pick up new or moved files."
    },
    {
      question: "How long does the initial index take?",
      answer: "It depends on drive size and speed. A typical 500 GB internal SSD with around 200,000 files takes a few minutes. External and network drives vary with connection speed. You can search immediately — results appear as indexing progresses."
    },
    {
      question: "What happens if I disconnect a drive?",
      answer: "The index for that drive is retained. You can still search and browse its contents — files just can't be opened until the drive is reconnected. Ordina clearly marks offline drives so you always know what you're looking at."
    },
    {
      question: "Which cloud services does Ordina support?",
      answer: "Google Drive, OneDrive, Dropbox, and iCloud Drive. Ordina indexes the cloud provider's local sync folder, so results appear whether files are downloaded locally or stored only in the cloud."
    },
    {
      question: "Does Ordina send my files or file names anywhere?",
      answer: "No. All index data is stored locally on your Mac in Application Support. The natural language filter runs entirely on-device. The only outbound network activity is OAuth for cloud provider sign-in (credentials stored in your Keychain) and Bonjour for Agent discovery on your local network."
    },
    {
      question: "Can I use Ordina on more than one Mac?",
      answer: "A Pro license is per-user and covers all Macs you personally own. The Ordina Agent can be installed on any Mac or headless server so you can search its drives from your main machine."
    },
    {
      question: "Is there a subscription?",
      answer: "No. Ordina Pro is a one-time purchase of $79.99 — yours to keep, including all future updates to the current major version. No renewal fees, no account required."
    },
  ]} />

  <!-- Waitlist -->
  <section class="waitlist-section fade-in">
    <EmailCapture app="Ordina" />
    <p class="privacy-note">
      By joining you agree to our <a href="/terms">Terms of Use</a>.
      Read the <a href="/privacy/ordina">Ordina Privacy Policy</a>.
    </p>
  </section>

</BaseLayout>

<style>
  .product-hero {
    text-align: center;
    padding: 4rem 0 3rem;
    max-width: 700px;
    margin: 0 auto;
  }

  .product-icon {
    width: 96px;
    height: 96px;
    border-radius: 22px;
    margin-bottom: 1.5rem;
  }

  .product-hero h1 {
    font-size: 2.75rem;
    margin-bottom: 0.5rem;
  }

  .tagline {
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--blue);
    margin-bottom: 1rem;
  }

  .hero-sub {
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--gray-dark);
    margin-bottom: 1.5rem;
  }

  .hero-meta {
    font-size: 0.9rem;
    color: var(--gray);
  }

  /* Feature sections */
  .feature-section {
    display: flex;
    gap: 2.5rem;
    align-items: flex-start;
    max-width: 900px;
    margin: 0 auto;
    padding: 3.5rem 0;
    border-bottom: 1px solid var(--gray-light);
  }

  .feature-section.alt {
    background: var(--gray-light);
    padding: 3.5rem calc((100% - 900px) / 2 + 1.5rem);
    margin: 0 calc(-1 * (100vw - 900px) / 2);
    max-width: 100vw;
    width: 100vw;
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    border-bottom: none;
    justify-content: center;
  }

  .feature-section.alt > .feature-icon,
  .feature-section.alt > .feature-body {
    max-width: 420px;
  }

  .feature-icon {
    font-size: 2.5rem;
    flex-shrink: 0;
    width: 56px;
    text-align: center;
    padding-top: 0.25rem;
  }

  .feature-body {
    flex: 1;
    max-width: 820px;
  }

  .feature-body h2 {
    font-size: 1.6rem;
    margin-bottom: 1rem;
  }

  .feature-body p {
    font-size: 1.05rem;
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  /* Drive table */
  .drive-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 1.25rem;
    font-size: 0.95rem;
  }

  .drive-table th {
    text-align: left;
    padding: 0.6rem 0.75rem;
    border-bottom: 2px solid var(--gray);
    color: var(--gray-dark);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .drive-table td {
    padding: 0.65rem 0.75rem;
    border-bottom: 1px solid #e0e0e0;
    color: var(--gray-dark);
  }

  .drive-table td.check { color: var(--green); font-weight: 700; text-align: center; }
  .drive-table td.dash  { color: var(--gray); text-align: center; }

  /* Code block */
  .code-block {
    background: #1a1a2e;
    border-radius: 10px;
    padding: 1rem 1.25rem;
    margin-top: 1.25rem;
  }

  .code-block code {
    font-family: "SF Mono", "Fira Code", "Fira Mono", monospace;
    font-size: 0.9rem;
    color: #a8d8ea;
    white-space: pre;
  }

  /* Mini feature grid */
  .mini-feature-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    margin-top: 1.25rem;
  }

  .mini-feature {
    background: #fff;
    border-radius: 10px;
    padding: 1rem 1.25rem;
  }

  .mini-feature h3 {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--blue);
    margin-bottom: 0.4rem;
  }

  .mini-feature p {
    font-size: 0.9rem;
    margin: 0;
    color: var(--gray-dark);
  }

  /* Pricing */
  .pricing-section {
    max-width: 760px;
    margin: 0 auto;
    padding: 3.5rem 0;
    text-align: center;
    border-bottom: none;
  }

  .pricing-section h2 {
    font-size: 1.6rem;
    margin-bottom: 2rem;
  }

  .pricing-cards {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
  }

  .pricing-card {
    flex: 1;
    max-width: 320px;
    background: var(--gray-light);
    border-radius: var(--radius);
    padding: 1.75rem;
    text-align: left;
  }

  .pricing-card.featured {
    background: var(--blue);
    color: #fff;
  }

  .pricing-card h3 {
    font-size: 1rem;
    margin-bottom: 0.75rem;
  }

  .pricing-card.featured h3 { color: rgba(255,255,255,0.8); }

  .price {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
  }

  .price-detail {
    font-size: 0.8rem;
    opacity: 0.75;
    margin-bottom: 1rem;
    color: var(--gray-dark);
  }

  .pricing-card.featured .price-detail { color: rgba(255,255,255,0.7); }

  .pricing-card ul {
    list-style: none;
    padding: 0;
    margin-top: 1rem;
  }

  .pricing-card ul li {
    font-size: 0.9rem;
    padding: 0.35rem 0;
    border-bottom: 1px solid rgba(0,0,0,0.06);
    color: var(--gray-dark);
  }

  .pricing-card.featured ul li {
    border-color: rgba(255,255,255,0.15);
    color: rgba(255,255,255,0.9);
  }

  .pricing-card ul li::before { content: "✓  "; }

  /* Waitlist */
  .waitlist-section {
    padding: 1rem 0 3rem;
    border-bottom: none;
  }

  .privacy-note {
    text-align: center;
    font-size: 0.8rem;
    color: var(--gray);
    margin-top: -1.5rem;
  }

  .privacy-note a {
    color: var(--gray-dark);
    text-decoration: underline;
  }

  .privacy-note a:hover {
    color: var(--blue);
  }

  @media (max-width: 768px) {
    .feature-section,
    .feature-section.alt {
      flex-direction: column;
      gap: 1.25rem;
      padding: 2.5rem 1rem;
      margin-left: 0;
      margin-right: 0;
      width: 100%;
      left: 0;
      right: 0;
    }

    .mini-feature-grid {
      grid-template-columns: 1fr;
    }

    .drive-table { font-size: 0.82rem; }

    .pricing-cards {
      flex-direction: column;
      align-items: stretch;
    }

    .pricing-card { max-width: 100%; }
  }
</style>
