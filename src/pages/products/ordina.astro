---
import ProductLayout from "../../layouts/ProductLayout.astro";

const title = "Ordina";
const icon = "/images/products/ordina/icon.png";
const tagline = "A fast, elegant writing environment designed for clarity and flow.";
---

<ProductLayout {title} {icon} {tagline}>
  <h2>Overview</h2>
  <p>
    Ordina is a focused writing environment built for people who want clarity,
    speed, and zero friction. Whether you're drafting ideas, writing long‑form
    content, or organizing thoughts, Ordina stays out of your way.
  </p>

  <h2>Key Features</h2>
  <ul>
    <li>Clean, distraction‑free interface</li>
    <li>Fast, responsive editor with instant saves</li>
    <li>Lightweight, elegant typography</li>
    <li>Perfect for notes, drafts, and long‑form writing</li>
  </ul>

  <h2>Why You'll Love It</h2>
  <p>
    Ordina is designed to feel invisible — a writing tool that amplifies your
    thinking instead of interrupting it.
  </p>

  <a href="#" class="cta">Download</a>
</ProductLayout>
