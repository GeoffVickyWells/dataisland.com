---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact" description="Get in touch with DataIsland Software.">

  <section class="contact fade-in">
    <h1>Contact</h1>

    <p>
      For support, business inquiries, or general questions, reach out anytime.
    </p>

    <p>
      <strong>Email:</strong><br />
      support@dataisland.com
    </p>

    <p>
      We typically respond within 1–2 business days.
    </p>
  </section>

</BaseLayout>

<style>
  .contact {
    max-width: 700px;
    margin: 0 auto;
    padding: 3rem 0;
  }

  .contact h1 {
    margin-bottom: 1.5rem;
  }

  .contact p {
    font-size: 1.1rem;
    margin-bottom: 1rem;
  }
</style>
