---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Privacy Policies — DataIsland Software" description="Privacy policies for DataIsland Software apps: CheckThis, Ordina, and FusionMD.">

  <section class="legal fade-in">
    <h1>Privacy Policies</h1>

    <p>
      DataIsland Software LLC is committed to building privacy-first tools. Our apps are designed
      to keep your data on your device. We do not operate servers that receive your documents,
      files, or email content. We do not require accounts.
    </p>

    <p>
      Select an app below to read its specific privacy policy. Each policy is also linked from
      that app's Mac App Store listing.
    </p>

    <div class="policy-links">
      <a href="/privacy/checkthis" class="policy-card">
        <strong>CheckThis</strong>
        <span>Email phishing detection for Apple Mail</span>
        <span class="arrow">Read policy →</span>
      </a>
      <a href="/privacy/ordina" class="policy-card">
        <strong>Ordina</strong>
        <span>File search across every drive</span>
        <span class="arrow">Read policy →</span>
      </a>
      <a href="/privacy/fusionmd" class="policy-card">
        <strong>FusionMD</strong>
        <span>Markdown document studio</span>
        <span class="arrow">Read policy →</span>
      </a>
    </div>

    <h2>General Principles</h2>
    <p>
      Across all DataIsland apps:
    </p>
    <ul>
      <li>No DataIsland server receives your content, documents, or personal files</li>
      <li>No account is required to use any DataIsland app</li>
      <li>No personal data is sold or shared with third parties for advertising</li>
      <li>Any optional cloud or AI features are opt-in and clearly disclosed</li>
    </ul>

    <h2>Contact</h2>
    <p>
      Privacy questions: <a href="mailto:support@dataisland.com">support@dataisland.com</a>
    </p>
  </section>

</BaseLayout>

<style>
  .legal {
    max-width: 800px;
    margin: 0 auto;
    padding: 3rem 0 5rem;
    border-bottom: none;
  }

  .legal h1 { font-size: 2.25rem; margin-bottom: 1.5rem; }
  .legal h2 { margin-top: 2.5rem; margin-bottom: 0.75rem; font-size: 1.2rem; }
  .legal p  { font-size: 1.05rem; line-height: 1.7; }

  ul {
    margin: 0.75rem 0 1rem 1.25rem;
    color: var(--gray-dark);
  }

  ul li { margin-bottom: 0.4rem; font-size: 1rem; }

  .policy-links {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin: 2rem 0;
  }

  .policy-card {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    background: var(--gray-light);
    border-radius: var(--radius);
    padding: 1.25rem 1.5rem;
    text-decoration: none;
    color: inherit;
    transition: var(--transition);
    border: 1px solid transparent;
  }

  .policy-card:hover {
    border-color: var(--blue);
    opacity: 1;
  }

  .policy-card strong { font-size: 1.05rem; color: #1a1a1a; }
  .policy-card span   { font-size: 0.9rem; color: var(--gray-dark); }
  .policy-card .arrow { color: var(--blue); font-weight: 600; margin-top: 0.25rem; }
</style>
