---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About DataIsland" description="Learn about DataIsland Software and our mission.">

  <section class="about fade-in">
    <h1>About DataIsland</h1>

    <p>
      DataIsland Software builds privacy‑first tools for writers, creators, and professionals.
      Our mission is simple: create clean, semantic, AI‑assisted apps that respect users,
      protect their data, and make complex workflows feel effortless.
    </p>

    <h2>Our Philosophy</h2>
    <p>
      We believe software should be predictable, transparent, and empowering. That means:
    </p>

    <ul>
      <li>Local‑first processing whenever possible</li>
      <li>Clear separation between meaning and appearance</li>
      <li>Tools that enhance your thinking, not replace it</li>
      <li>Design that stays out of your way</li>
    </ul>

    <h2>Our Products</h2>
    <p>
      DataIsland builds focused, high‑quality apps:
    </p>

    <ul>
      <li><strong>Fusion</strong> — a semantic writing environment</li>
      <li><strong>Check This</strong> — a privacy‑first email trust analyzer</li>
    </ul>

    <h2>Contact</h2>
    <p>
      For support or inquiries:
      <br />
      <strong>support@dataisland.com</strong>
    </p>
  </section>

</BaseLayout>

<style>
  .about {
    max-width: 800px;
    margin: 0 auto;
    padding: 3rem 0;
  }

  .about h1 {
    margin-bottom: 1.5rem;
  }

  .about h2 {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .about p {
    font-size: 1.05rem;
  }

  ul {
    margin: 1rem 0 1.5rem 1.25rem;
    color: var(--gray-dark);
  }

  ul li {
    margin-bottom: 0.5rem;
  }
</style>
