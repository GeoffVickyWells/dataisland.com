---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About DataIsland" description="DataIsland Software LLC — privacy-first Mac apps for creators, writers, and professionals.">

  <section class="about fade-in">
    <h1>About DataIsland</h1>

    <p>
      DataIsland Software LLC builds privacy-first Mac apps for creators, writers, and professionals.
      Our tools are native, fast, and designed to keep your data on your device — not in the cloud.
    </p>

    <h2>Our Philosophy</h2>
    <p>
      Most software has shifted toward subscriptions, cloud storage, and accounts.
      We think that's the wrong direction for professional tools. Our apps are:
    </p>
    <ul>
      <li><strong>Local-first</strong> — your data stays on your Mac, not on our servers</li>
      <li><strong>One-time purchases</strong> — no subscriptions, no annual fees</li>
      <li><strong>No account required</strong> — download, run, done</li>
      <li><strong>Native macOS</strong> — built with SwiftUI, not Electron</li>
    </ul>

    <h2>Our Apps</h2>

    <div class="app-list">
      <div class="app-entry">
        <strong>FusionMD</strong>
        <span>A Markdown document studio with a template engine, AI writing assistant, and IDML export for Affinity and InDesign. The only Markdown editor that goes all the way to professional layout.</span>
        <a href="/products/fusionmd">Learn more →</a>
      </div>
      <div class="app-entry">
        <strong>Ordina</strong>
        <span>File search across every drive you own — internal, external, network, cloud, and remote. One search box. Results in under a second.</span>
        <a href="/products/ordina">Learn more →</a>
      </div>
      <div class="app-entry">
        <strong>CheckThis</strong>
        <span>Email phishing and fraud analysis for Apple Mail. A silent Mail extension color-codes your inbox, and one click delivers a full forensic verdict on any email.</span>
        <a href="/products/checkthis">Learn more →</a>
      </div>
    </div>

    <h2>Contact</h2>
    <p>
      For support, questions, or feedback:
      <br />
      <strong><a href="mailto:support@dataisland.com">support@dataisland.com</a></strong>
    </p>
    <p>
      We typically respond within 1–2 business days.
    </p>

    <h2>Legal</h2>
    <p>
      DataIsland Software LLC &nbsp;·&nbsp; <a href="/privacy">Privacy Policies</a> &nbsp;·&nbsp; <a href="/terms">Terms of Use</a>
    </p>
  </section>

</BaseLayout>

<style>
  .about {
    max-width: 800px;
    margin: 0 auto;
    padding: 3rem 0 5rem;
    border-bottom: none;
  }

  .about h1 {
    font-size: 2.25rem;
    margin-bottom: 1.5rem;
  }

  .about h2 {
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    font-size: 1.25rem;
  }

  .about p {
    font-size: 1.05rem;
    line-height: 1.7;
  }

  ul {
    margin: 0.75rem 0 1.5rem 1.25rem;
    color: var(--gray-dark);
  }

  ul li {
    margin-bottom: 0.5rem;
    font-size: 1rem;
    line-height: 1.5;
  }

  .app-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin: 1rem 0;
  }

  .app-entry {
    background: var(--gray-light);
    border-radius: var(--radius);
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .app-entry strong {
    font-size: 1.05rem;
  }

  .app-entry span {
    font-size: 0.95rem;
    color: var(--gray-dark);
    line-height: 1.5;
  }

  .app-entry a {
    font-size: 0.9rem;
    font-weight: 600;
    align-self: flex-start;
  }
</style>
