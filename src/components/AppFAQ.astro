---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  items: FAQItem[];
  heading?: string;
}

const { items, heading = "Frequently asked questions" } = Astro.props;
---

<section class="faq-section fade-in">
  <h2>{heading}</h2>
  <div class="faq-list">
    {items.map((item) => (
      <details class="faq-item">
        <summary class="faq-question">
          {item.question}
          <span class="chevron" aria-hidden="true">›</span>
        </summary>
        <p class="faq-answer">{item.answer}</p>
      </details>
    ))}
  </div>
</section>

<style>
  .faq-section {
    max-width: 760px;
    margin: 0 auto;
    padding: 3.5rem 0;
    border-bottom: 1px solid var(--gray-light);
  }

  .faq-section h2 {
    font-size: 1.6rem;
    margin-bottom: 2rem;
    text-align: center;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .faq-item {
    background: var(--gray-light);
    border-radius: 10px;
    overflow: hidden;
  }

  .faq-item[open] {
    background: #fff;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.07);
  }

  .faq-question {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 1.1rem 1.25rem;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    list-style: none;
    user-select: none;
    color: var(--text, #111);
  }

  .faq-question::-webkit-details-marker { display: none; }

  .chevron {
    font-size: 1.3rem;
    color: var(--blue);
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
    flex-shrink: 0;
    line-height: 1;
  }

  .faq-item[open] .chevron {
    transform: rotate(90deg);
  }

  .faq-answer {
    padding: 0 1.25rem 1.25rem;
    margin: 0;
    font-size: 0.97rem;
    line-height: 1.7;
    color: var(--gray-dark);
    animation: answerIn 0.35s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  @keyframes answerIn {
    from { opacity: 0; transform: translateY(-6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 768px) {
    .faq-section {
      padding: 2.5rem 1rem;
    }
  }
</style>
