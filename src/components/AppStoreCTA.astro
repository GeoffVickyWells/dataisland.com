---
interface Props {
  href?: string;
  comingSoon?: boolean;
}

const { href = "#", comingSoon = true } = Astro.props;
---

<div class="cta-wrap">
  <a
    href={href}
    class={`mac-store-btn${comingSoon ? " stub" : ""}`}
    aria-disabled={comingSoon ? "true" : undefined}
    tabindex={comingSoon ? -1 : undefined}
  >
    <svg class="apple-icon" viewBox="0 0 814 1000" fill="currentColor" aria-hidden="true">
      <path d="M788.1 340.9c-5.8 4.5-108.2 62.2-108.2 190.5 0 148.4 130.3 200.9 134.2 202.2-.6 3.2-20.7 71.9-68.7 141.9-42.8 61.6-87.5 123.1-155.5 123.1s-85.5-39.5-164-39.5c-76.5 0-103.7 40.8-165.9 40.8s-105-57.8-155.5-127.4C46 790.7 0 663 0 541.8c0-207.3 106.3-317.3 248.3-317.3 63.1 0 115.5 41.5 155.5 41.5 38.4 0 98.5-44 170.5-44 27.4 0 108.2 2.6 168.4 101.2zm-234.9-230.9c32.1-38.2 55.5-91.8 55.5-145.4 0-7.4-.6-15.3-1.9-21.7-52.6 2-114.3 35.3-151.7 77.2-28.2 31.9-55.1 85.5-55.1 139.7 0 8.1 1.3 16.2 1.9 18.8 3.2.6 8.4 1.3 13.6 1.3 47.1 0 106.3-31.3 137.7-69.9z"/>
    </svg>
    <span class="btn-text">
      <span class="btn-sub">{comingSoon ? "Coming Soon to the" : "Download on the"}</span>
      <span class="btn-main">Mac App Store</span>
    </span>
  </a>
  {comingSoon && (
    <p class="cta-nudge">
      Not yet available — <a href="#waitlist">join the waitlist</a> for 10% off at launch.
    </p>
  )}
</div>

<style>
  .cta-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    margin-top: 1.5rem;
  }

  .mac-store-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    background: #000;
    color: #fff;
    text-decoration: none;
    border-radius: 12px;
    padding: 0.65rem 1.4rem;
    transition: background 0.18s, transform 0.15s, opacity 0.15s;
    border: 1px solid rgba(255,255,255,0.08);
  }

  .mac-store-btn:not(.stub):hover {
    background: #1a1a1a;
    transform: translateY(-1px);
  }

  .mac-store-btn.stub {
    opacity: 0.55;
    cursor: default;
    pointer-events: none;
  }

  .apple-icon {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
  }

  .btn-text {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
  }

  .btn-sub {
    font-size: 0.65rem;
    font-weight: 400;
    letter-spacing: 0.02em;
    opacity: 0.85;
  }

  .btn-main {
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .cta-nudge {
    font-size: 0.83rem;
    color: var(--gray);
    margin: 0;
  }

  .cta-nudge a {
    color: var(--blue);
    text-decoration: none;
  }

  .cta-nudge a:hover {
    text-decoration: underline;
  }
</style>
