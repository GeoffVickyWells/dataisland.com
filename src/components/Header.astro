---
---

<header class="site-header">
  <div class="container">
    <a href="/" class="logo-link">
      <img src="/images/brand/palm.png" alt="DataIsland Logo" class="logo" />
      <span class="site-name">DataIsland Software</span>
    </a>

    <nav class="nav">
      <a href="/">Home</a>
      <a href="/tutorials">Tutorials</a>
      <a href="/about">About</a>
      <a href="/contact">Contact</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    width: 100%;
    padding: 1rem 0;
    border-bottom: 1px solid var(--gray-light);
    background: #fff;
    position: sticky;
    top: 0;
    z-index: 1000;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    color: inherit;
  }

  .logo {
    width: 48px;
    height: 48px;
    object-fit: contain;
  }

  .site-name {
    font-weight: 600;
    font-size: 1.1rem;
    color: var(--gray-dark);
  }

  .nav a {
    margin-left: 1.5rem;
    font-size: 1rem;
    color: var(--gray-dark);
    transition: var(--transition);
  }

  .nav a:hover {
    color: var(--blue);
  }

  @media (max-width: 768px) {
    .site-name {
      display: none;
    }

    .nav {
      display: none;
    }
  }
</style>
