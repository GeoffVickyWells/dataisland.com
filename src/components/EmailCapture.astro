---
const { label = "Start Free Trial", subtext = "No spam. Unsubscribe anytime." } = Astro.props;
---

<form class="email-capture" method="post" action="#">
  <h3>{label}</h3>

  <div class="field-row">
    <input
      type="email"
      name="email"
      placeholder="Your email address"
      required
    />
    <button type="submit">Join</button>
  </div>

  <p class="subtext">{subtext}</p>
</form>

<style>
  .email-capture {
    background: var(--blue-light);
    padding: 2rem;
    border-radius: var(--radius);
    text-align: center;
    max-width: 500px;
    margin: 3rem auto;
  }

  .email-capture h3 {
    margin-bottom: 1rem;
  }

  .field-row {
    display: flex;
    gap: 0.75rem;
    margin: 1rem 0;
  }

  .field-row input {
    flex: 1;
    padding: 0.75rem 1rem;
    border-radius: var(--radius);
    border: 1px solid var(--gray);
    font-size: 1rem;
  }

  .field-row button {
    padding: 0.75rem 1.25rem;
    font-size: 1rem;
  }

  .subtext {
    margin-top: 0.5rem;
    font-size: 0.85rem;
    color: var(--gray-dark);
  }

  @media (max-width: 600px) {
    .field-row {
      flex-direction: column;
    }

    .field-row button {
      width: 100%;
    }
  }
</style>
