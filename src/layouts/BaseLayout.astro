---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const { title = "DataIsland Software", description = "Privacy‑first tools for creators and professionals." } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="stylesheet" href="/styles/global.css" />
  </head>

  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <script is:inline>
      function checkFadeIns() {
        document.querySelectorAll(".fade-in:not(.animate)").forEach(function (el) {
          var rect = el.getBoundingClientRect();
          if (rect.top < window.innerHeight * 0.88) {
            el.classList.add("animate");
          }
        });
      }

      // Small delay so CSS opacity:0 is painted before we check
      setTimeout(function () {
        checkFadeIns();
        window.addEventListener("scroll", checkFadeIns, { passive: true });
      }, 150);
    </script>
  </body>
</html>
