---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const { title = "DataIsland Software", description = "Privacy‑first tools for creators and professionals." } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="stylesheet" href="/styles/global.css" />
  </head>

  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <script is:inline>
      function check() {
        document.querySelectorAll(".fade-in:not(.go)").forEach(function (el) {
          var rect = el.getBoundingClientRect();
          if (rect.top < window.innerHeight * 0.90) {
            el.classList.add("go");
          }
        });
      }

      window.addEventListener("scroll", check, { passive: true });
      window.addEventListener("load", check);
      document.addEventListener("DOMContentLoaded", check);
      document.addEventListener("mousemove", check, { once: true, passive: true });
    </script>
  </body>
</html>
