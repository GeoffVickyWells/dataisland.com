---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const { title = "DataIsland Software", description = "Privacy‑first tools for creators and professionals." } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="stylesheet" href="/styles/global.css" />
  </head>

  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <script is:inline>
      window.addEventListener("load", function () {
        var els = document.querySelectorAll(".fade-in");

        // Step 1: hide elements, no transition yet
        els.forEach(function (el) {
          el.style.opacity = "0";
          el.style.transform = "translateY(60px)";
          el.style.transition = "none";
        });

        // Step 2: double requestAnimationFrame ensures the browser
        // fully paints the hidden state before transitions are enabled
        requestAnimationFrame(function () {
          requestAnimationFrame(function () {

            // Step 3: enable transitions now that hidden state is painted
            els.forEach(function (el) {
              el.style.transition = "opacity 0.9s ease, transform 0.9s ease";
            });

            var observer = new IntersectionObserver(function (entries) {
              entries.forEach(function (entry) {
                if (entry.isIntersecting) {
                  entry.target.style.opacity = "1";
                  entry.target.style.transform = "translateY(0)";
                  observer.unobserve(entry.target);
                }
              });
            }, { threshold: 0.1, rootMargin: "0px 0px -60px 0px" });

            els.forEach(function (el) {
              observer.observe(el);
            });

          });
        });
      });
    </script>
  </body>
</html>
