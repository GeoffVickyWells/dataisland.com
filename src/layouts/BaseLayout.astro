---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const { title = "DataIsland Software", description = "Privacy‑first tools for creators and professionals." } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="stylesheet" href="/styles/global.css" />
  </head>

  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <script is:inline>
      (function () {
        var els = document.querySelectorAll(".fade-in");

        // Set hidden state with direction-aware transform, no transition yet
        els.forEach(function (el) {
          el.style.opacity = "0";
          el.style.transition = "none";
          if (el.classList.contains("left")) {
            el.style.transform = "translateX(-80px)";
          } else if (el.classList.contains("right")) {
            el.style.transform = "translateX(80px)";
          } else {
            el.style.transform = "translateY(50px)";
          }
        });

        // 100ms gives the browser time to paint the hidden state
        // before transitions are enabled and the observer starts watching
        setTimeout(function () {
          els.forEach(function (el) {
            el.style.transition = "opacity 0.8s ease, transform 0.8s ease";
          });

          var observer = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.style.opacity = "1";
                entry.target.style.transform = "translate(0, 0)";
                observer.unobserve(entry.target);
              }
            });
          }, { threshold: 0.1 });

          els.forEach(function (el) {
            observer.observe(el);
          });
        }, 100);
      })();
    </script>
  </body>
</html>
